{
  "manifest_version": 3,
  "name": "CtrlB Decompose",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "description": "Compress log lines into structural patterns with statistics, anomalies, and correlations.",
  "permissions": ["sidePanel", "contextMenus", "storage", "scripting", "activeTab"],
  "background": {
    "service_worker": "background/sw.js"
  },
  "side_panel": {
    "default_path": "panel/panel.html"
  },
  "action": {
    "default_title": "CtrlB Decompose — Log Analyzer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
